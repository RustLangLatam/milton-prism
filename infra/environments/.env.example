# Copy to the environment directory (.env next to docker-compose.yaml) and fill in values.
# NEVER commit .env to version control.

# ── Cache ─────────────────────────────────────────────────────────────────────
# KeyDB / Redis password — must match what services have in their config.toml
KEYDB_PASSWORD=

# ── Gateway ───────────────────────────────────────────────────────────────────
# API key validated by milton-prism-gateway on every inbound request
GATEWAY_API_KEY=

# ── Generation worker ─────────────────────────────────────────────────────────
# Auth mode for agent containers. Two values:
#   apikey       — (default/production) uses ANTHROPIC_API_KEY; billed per-token.
#   subscription — uses Claude Code OAuth credentials; billed via subscription plan.
PRISM_AGENT_AUTH=

# Anthropic API key — required when PRISM_AGENT_AUTH=apikey.
# NEVER commit a real key — set it in the shell or keep this file out of VCS.
ANTHROPIC_API_KEY=

# HOST path to the Claude Code ~/.claude directory — required for subscription mode.
# Bind-mounted read-write into each agent container at /home/prism/.claude so
# Claude Code always sees the live OAuth token state (no stale snapshot).
# Must be the HOST path — the Docker daemon resolves bind-mounts from the host.
PRISM_CLAUDE_DIR=

# Host-absolute path to the monorepo root (e.g. /mnt/usr/src/desarrollo/gopath/milton/milton-prism).
# Must be the HOST path — the Docker daemon resolves bind-mounts from the host
# filesystem, not from inside the generation-worker container.
PRISM_MONOREPO_PATH=

# Shared workspace directory for ephemeral generation workspaces (DooD).
# Must be the same path on host and inside the generation-worker container.
PRISM_WORKSPACE_PATH=

# Go module cache on the HOST — mounted read-only into each ephemeral agent
# container at /go/pkg/mod so the agent skips re-downloading dependencies.
# Set to your $GOPATH/pkg/mod. Leave empty to disable (agent downloads fresh).
PRISM_GO_MOD_CACHE=

# Max services to generate in parallel within a single migration job.
# Each container runs go build + go test, so be conservative with RAM.
# Machine: 16 vCPUs, 15 GB RAM (~6 GB available). 1 GB cap per container.
# Safe ceiling for Conduit (3 services): 3. Set to 1 for subscription measurement runs.
PRISM_GENERATION_CONCURRENCY=
