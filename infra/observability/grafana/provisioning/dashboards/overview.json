      "pluginVersion": "11.2.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(grpc_server_handled_total{grpc_service!=\"grpc.health.v1.Health\"}[5m]))",
